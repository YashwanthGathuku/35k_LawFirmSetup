# =============================================================================
# Tegifa Legal — Environment Configuration
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Domain & TLS ---
CADDY_SITE_ADDRESS=tegifa.yourdomain.com

# --- LLM Backend ---
MODEL_FILE=Phi-4-mini-instruct.Q8_0.gguf
MODEL_TYPE=llama.cpp
# MODEL_TYPE=ollama

# --- Database ---
POSTGRES_USER=tegifa_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
POSTGRES_DB=tegifa_memory
DATABASE_URI=postgresql://tegifa_admin:CHANGE_ME_STRONG_RANDOM_PASSWORD@postgres-db:5432/tegifa_memory

# --- Neo4j (Knowledge Graph) ---
NEO4J_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# --- Auth Cookie ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_COOKIE_KEY=CHANGE_ME_RANDOM_HEX_STRING

# --- Webhook Security ---
# Shared secret for authenticating webhook calls between Streamlit and backend
WEBHOOK_SECRET=CHANGE_ME_RANDOM_SECRET

# --- Ollama ---
OLLAMA_HOST=http://ollama:11434

# --- LLM Server (llama.cpp) ---
LLM_API_BASE=http://llm-server:8080/v1
