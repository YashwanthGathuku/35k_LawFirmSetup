*.db
*.sqlite3
chroma_db/
storage/

# --- Coverage & Testing ---
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/

# --- Docker ---
n8n-data/

# --- Models (large files) ---
models/
*.gguf
*.bin

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Uploaded docs ---
docs/
